@startuml
!theme plain
top to bottom direction

skinparam defaultFontName "Arial"
skinparam defaultFontSize 10
skinparam backgroundColor #FFFFFF
skinparam ArrowColor #333333
skinparam ArrowThickness 1.4
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 25
skinparam ranksep 30

skinparam rectangle {
  RoundCorner 8
  BorderThickness 1.2
  BorderColor #222222
  BackgroundColor #FFFFFF
}

skinparam package {
  RoundCorner 8
  BorderThickness 1.6
  BorderColor #222222
  FontSize 11
  FontStyle bold
}

skinparam actor {
  BorderColor #2C3E50
  BackgroundColor #D6EAF8
  FontStyle bold
}

title
<size:16><b>Sales Revenue Forecasting System Architecture</b></size>
end title

package "Layer 1 - Data Sources" #D6EAF8 {
  rectangle "M5 Dataset\nsales_train_evaluation.csv\ncalendar.csv\nsell_prices.csv" as DATA
}

package "Layer 2 - Processing Pipeline" #D5F5E3 {
  rectangle "Preprocessing\nsrc/preprocessing.py\nMelt sales, merge calendar/prices,\nclean data, compute revenue" as PRE
  rectangle "Feature Engineering\nsrc/feature_engineering.py\nDate, lag, rolling, growth,\nprice and encoded features" as FE
  rectangle "Prepared Data\ndata/processed + data/dataset\nprocessed_sales.csv\nfeatured_daily_sales.csv" as PREPARED
}

package "Layer 3 - Forecasting Models" #FEF9E7 {
  rectangle "Training Pipeline\nsrc/models/train_and_evaluate.py\nChronological 70/30 split" as TRAIN
  rectangle "Models\nLinear Regression\nRandom Forest\nXGBoost\nARIMA / SARIMA / Prophet" as MODELS
  rectangle "Evaluation\nMAE, RMSE, MAPE, R2\nBest: XGBoost\nRMSE 15.33\nR2 0.9990" as EVAL #E9F7EF
}

package "Layer 4 - Stored Outputs" #F4ECF7 {
  rectangle "Model Outputs\noutputs/models/*.pkl\nevaluation_metrics.csv" as MODEL_OUT
  rectangle "Dashboard Data\ndata/dataset/*.json\ndata/predictions/forecast.csv\nplot_data.json\nproduct_forecasts.json" as DASH_OUT
}

package "Layer 5 - Application and Sustainability" #FDEDEC {
  rectangle "Streamlit Dashboard\nmain.py -> app/app.py\nHome, Sales, Forecast,\nProduct, Revenue, Models,\nReports, Sustainability" as APP
  rectangle "Sustainability Analytics\nsrc/sustainability/*\nInventory simulation,\nshipment consolidation,\nCO2 and cost savings" as SUST
  rectangle "Sustainability Results\n18 trips reduced\n5065.2 kg CO2 saved\n1890 L fuel saved\n$9706.5 cost saved" as SUST_OUT #E9F7EF
}

actor "Analyst /\nDecision Maker" as USER

DATA --> PRE : raw retail files
PRE --> FE : cleaned sales data
FE --> PREPARED : engineered dataset
PREPARED --> TRAIN : featured_daily_sales.csv
TRAIN --> MODELS : train and forecast
MODELS --> EVAL : compare models
EVAL --> MODEL_OUT : save metrics and models
EVAL --> DASH_OUT : save predictions
DASH_OUT --> APP : load visual data
MODEL_OUT --> APP : model metrics
DASH_OUT --> SUST : product_forecasts.json
SUST --> SUST_OUT : optimized logistics KPIs
SUST_OUT --> APP : sustainability page
APP --> USER : charts, KPIs, reports

@enduml
